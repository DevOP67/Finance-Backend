{
  "name": "finance-api",
  "version": "2.0.0",
  "description": "Production-ready Finance Dashboard REST API — Express + PostgreSQL",
  "main": "src/app.js",
  "scripts": {
    "start":   "node src/app.js",
    "dev":     "node --watch src/app.js",
    "migrate": "node migrate.js",
    "test":    "jest --runInBand --forceExit",
    "test:watch": "jest --watch"
  },
  "engines": { "node": ">=18" },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  },
  "dependencies": {
    "bcryptjs":           "^2.4.3",
    "dotenv":             "^16.3.1",
    "express":            "^4.18.2",
    "express-rate-limit": "^7.3.1",
    "express-validator":  "^7.0.1",
    "helmet":             "^7.1.0",
    "jsonwebtoken":       "^9.0.0",
    "pg":                 "^8.11.3",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
